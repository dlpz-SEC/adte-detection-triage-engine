# =============================================================================
# ADTE — Automated Detection Triage Engine
# Environment configuration
# =============================================================================

# --- Threat intelligence API keys (optional — mock fallback if unset) ---
ADTE_ABUSEIPDB_KEY=your-abuseipdb-key
ADTE_VT_API_KEY=your-virustotal-key
ADTE_OTX_KEY=your-otx-key           # anonymous OTX works without a key

# --- LLM narrative summaries (optional — deterministic fallback if unset) ---
ANTHROPIC_API_KEY=your-anthropic-key

# --- Wazuh Indexer (OpenSearch) connection ---
# Required only when running with --source wazuh.
# ADTE_WAZUH_HOST defaults to https://localhost:9200 when unset.
ADTE_WAZUH_HOST=https://localhost:9200
ADTE_WAZUH_USER=your-wazuh-username
ADTE_WAZUH_PASS=your-wazuh-password

# TLS certificate verification for the Wazuh Indexer connection.
# Default: true (verify certificates — safe for production).
# Set to false ONLY in local development environments using self-signed
# certificates.  NEVER set false against a non-localhost host; doing so
# silently exposes credentials to man-in-the-middle attacks.
ADTE_WAZUH_VERIFY_SSL=true

# --- Azure (future Sentinel integration — not currently used) ---
AZURE_TENANT_ID=00000000-0000-0000-0000-000000000000

# =============================================================================
# RBAC API Keys
#
# Each role maps to an API key sent via the X-ADTE-Key header.
# Role hierarchy: readonly < analyst < senior_analyst < admin
# Higher roles inherit all permissions of lower roles.
# =============================================================================
ADTE_API_KEY_ADMIN=changeme-admin-key
ADTE_API_KEY_SENIOR=changeme-senior-key
ADTE_API_KEY_ANALYST=changeme-analyst-key
ADTE_API_KEY_READONLY=changeme-readonly-key

# =============================================================================
# CORS — Allowed origins (comma-separated)
# =============================================================================
ADTE_CORS_ORIGINS=http://localhost:5000

# =============================================================================
# Safety gates (defence-in-depth)
#
# All gates default to the MOST RESTRICTIVE setting.  You must
# explicitly relax each gate to allow automated actions.
# Gates are evaluated in the order listed below; all must pass.
# =============================================================================

# Gate 1: Emergency kill switch.
# When true, ALL automated actions are immediately halted regardless
# of any other setting.  Use this to stop runaway automation.
ADTE_KILL_SWITCH=false

# Gate 2: Dry-run mode (default: true).
# When true, the engine evaluates and scores incidents but never
# executes any write/mutate operations (API calls, ticket creation,
# account disabling, etc.).  Set to false to allow writes.
ADTE_DRY_RUN=true

# Gate 3: Execution opt-in (default: false).
# Must be explicitly set to true to permit automated actions.
# Acts as a second confirmation beyond disabling dry_run.
ADTE_EXECUTION_ENABLED=false

# Gate 4: Tenant allowlist (comma-separated source system tenant IDs).
# If set, only incidents from these tenants may be actioned.
# Leave empty to allow all tenants (open gate).
ADTE_TENANT_ALLOWLIST=

# Gate 5: User allowlist (comma-separated UPNs).
# If set, only incidents involving these users may be actioned
# UNLESS the incident severity is High or Critical (which always
# bypasses the user allowlist).  Leave empty to allow all users.
ADTE_USER_ALLOWLIST=

# Gate 6: Action allowlist (comma-separated action type strings).
# Only these action types may be executed.  Default permits only
# low-risk operations.  Add types like DISABLE_ACCOUNT,
# REVOKE_SESSIONS as you gain confidence.
ADTE_ACTION_ALLOWLIST=CLOSE_INCIDENT,POST_COMMENT
